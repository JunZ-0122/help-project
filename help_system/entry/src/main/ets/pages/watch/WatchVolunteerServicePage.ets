import router from '@ohos.router';
import { promptAction } from '@kit.ArkUI';
import { NavBackButton } from '../../components/NavBackButton';
import { WatchButton } from '../../components/WatchButton';
import { OrderApi } from '../../services/ApiService';
import { DateUtil } from '../../utils/DateUtil';
import type { VolunteerOrder } from '../../models/Order';

/**
 * жүӢиЎЁпјҡеҝ—ж„ҝиҖ…и®ўеҚ•жңҚеҠЎдёӯ / е®ҢжҲҗпјҲеҜ№йҪ?OrderApiпјҢж—  WebSocketпјүгҖ?
 */
@Entry
@Component
struct WatchVolunteerServicePage {
  @State orderId: string = '';
  @State isLoading: boolean = true;
  @State isUpdating: boolean = false;
  @State order: VolunteerOrder | null = null;
  @State elapsedSec: number = 0;
  private tickTimer: number = -1;

  aboutToAppear(): void {
    const p = router.getParams() as Record<string, string>;
    if (p && p['id']) {
      this.orderId = p['id'] as string;
    }
    this.load();
  }

  aboutToDisappear(): void {
    this.clearTimer();
  }

  private clearTimer(): void {
    if (this.tickTimer !== -1) {
      clearInterval(this.tickTimer);
      this.tickTimer = -1;
    }
  }

  private startTimerIfNeeded(o: VolunteerOrder): void {
    this.clearTimer();
    if (o.status !== 'in-progress') {
      return;
    }
    const startStr = o.startedAt || o.acceptedAt;
    const startMs = startStr ? new Date(startStr).getTime() : Date.now();
    const tick = (): void => {
      this.elapsedSec = Math.max(0, Math.floor((Date.now() - startMs) / 1000));
    };
    tick();
    this.tickTimer = setInterval(tick, 1000);
  }

  private formatElapsed(sec: number): string {
    const m = Math.floor(sec / 60);
    const s = sec % 60;
    return `${m}еҲ?{s < 10 ? '0' : ''}${s}з§’`;
  }

  private async load(): Promise<void> {
    if (!this.orderId) {
      this.isLoading = false;
      return;
    }
    this.isLoading = true;
    try {
      const o = await OrderApi.getOrderDetail(this.orderId);
      this.order = o;
      this.startTimerIfNeeded(o);
    } catch (e) {
      const err = e as Error;
      promptAction.showToast({ message: err.message || 'еҠ иҪҪеӨұиҙҘ', duration: 2000 });
    } finally {
      this.isLoading = false;
    }
  }

  private statusLabel(s: string): string {
    switch (s) {
      case 'accepted':
        return 'е·ІжҺҘеҚ?;
      case 'in-progress':
        return 'жңҚеҠЎдё?;
      case 'completed':
        return 'е·Іе®ҢжҲ?;
      case 'cancelled':
        return 'е·ІеҸ–ж¶?;
      default:
        return s;
    }
  }

  private safeText(value: string | undefined, fallback: string): string {
    if (!value) {
      return fallback;
    }
    const t = value.trim();
    if (t.length === 0) {
      return fallback;
    }
    if (/^[\?пјҹпҝҪ]+$/.test(t)) {
      return fallback;
    }
    return t;
  }

  private startService(): void {
    if (!this.order || this.order.status !== 'accepted' || this.isUpdating) {
      return;
    }
    this.isUpdating = true;
    OrderApi.updateOrderStatus(this.orderId, 'in-progress')
      .then(() => {
        promptAction.showToast({ message: 'е·ІејҖе§ӢжңҚеҠ?, duration: 1500 });
        this.load();
      })
      .catch((err: Error) => {
        promptAction.showToast({ message: err.message || 'ж“ҚдҪңеӨұиҙҘ', duration: 2000 });
      })
      .finally(() => {
        this.isUpdating = false;
      });
  }

  private completeService(): void {
    if (!this.order || this.order.status !== 'in-progress' || this.isUpdating) {
      return;
    }
    promptAction.showDialog({
      title: 'е®ҢжҲҗжңҚеҠЎ',
      message: 'зЎ®и®Өж Үи®°дёәе·Іе®ҢжҲҗпј?,
      buttons: [
        { text: 'еҸ–ж¶Ҳ', color: '#666666' },
        { text: 'е®ҢжҲҗ', color: '#10b981' }
      ]
    }).then((result) => {
      if (result.index !== 1) {
        return;
      }
      this.isUpdating = true;
      OrderApi.completeOrder(this.orderId)
        .then(() => {
          this.clearTimer();
          promptAction.showToast({ message: 'жңҚеҠЎе·Іе®ҢжҲ?, duration: 1500 });
          router.replaceUrl({
            url: 'pages/watch/WatchVolunteerReviewPage',
            params: { id: this.orderId }
          }).catch((err: Error) => {
            console.error('nav review failed:', err);
          });
        })
        .catch((err: Error) => {
          promptAction.showToast({ message: err.message || 'ж“ҚдҪңеӨұиҙҘ', duration: 2000 });
        })
        .finally(() => {
          this.isUpdating = false;
        });
    });
  }

  build() {
    Column() {
      Row({ space: 8 }) {
        NavBackButton()
        Text('жңҚеҠЎиҝӣеәҰ')
          .fontSize(14)
          .fontWeight(FontWeight.Medium)
          .layoutWeight(1)
      }
      .width('100%')
      .padding({ left: 0, right: 0, top: 0, bottom: 6 })
      .backgroundColor('#ffffff')

      if (this.isLoading) {
        Column({ space: 8 }) {
          LoadingProgress().width(32).height(32)
          Text('еҠ иҪҪдё?..').fontSize(13).fontColor('#64748b')
        }
        .layoutWeight(1)
        .width('100%')
        .justifyContent(FlexAlign.Center)
      } else if (!this.order) {
        Text('ж— и®ўеҚ•ж•°жҚ?)
          .layoutWeight(1)
          .fontColor('#94a3b8')
      } else {
        Scroll() {
          Column({ space: 12 }) {
            Text(this.safeText(this.order.title, 'и®ўеҚ•'))
              .fontSize(13)
              .fontWeight(FontWeight.Medium)
            Text(this.statusLabel(this.order.status))
              .fontSize(11)
              .fontColor('#2563eb')
            Text(this.safeText(this.order.location, 'дҪҚзҪ®жңӘеЎ«еҶ?))
              .fontSize(10)
              .fontColor('#64748b')
            Text(`жұӮеҠ©иҖ…пјҡ${this.safeText(this.order.helpSeekerName, 'жұӮеҠ©иҖ?)}`)
              .fontSize(10)
              .fontColor('#64748b')
            Text(`жҺҘеҚ•ж—¶й—ҙпј?{DateUtil.format(this.order.acceptedAt, 'MM-DD HH:mm')}`)
              .fontSize(10)
              .fontColor('#94a3b8')

            if (this.order.status === 'in-progress') {
              Text(`жң¬ж¬Ўи®Ўж—¶пј?{this.formatElapsed(this.elapsedSec)}`)
                .fontSize(12)
                .fontWeight(FontWeight.Medium)
                .fontColor('#0f172a')
            }

            if (this.order.status === 'accepted') {
              WatchButton({
                text: this.isUpdating ? '...' : 'ејҖе§ӢжңҚеҠ?,
                buttonType: 'primary',
                buttonSize: 'medium',
                buttonWidth: '100%',
                buttonEnabled: !this.isUpdating,
                onClick: () => { this.startService(); }
              })
            }

            if (this.order.status === 'in-progress') {
              WatchButton({
                text: this.isUpdating ? '...' : 'е®ҢжҲҗжңҚеҠЎ',
                buttonType: 'primary',
                buttonSize: 'medium',
                buttonWidth: '100%',
                buttonEnabled: !this.isUpdating,
                onClick: () => { this.completeService(); }
              })
            }

            if (this.order.status === 'completed') {
              WatchButton({
                text: 'еҺ»иҜ„д»?,
                buttonType: 'secondary',
                buttonSize: 'medium',
                buttonWidth: '100%',
                onClick: () => {
                  router.pushUrl({
                    url: 'pages/watch/WatchVolunteerReviewPage',
                    params: { id: this.orderId }
                  }).catch((err: Error) => {
                    console.error('nav review failed:', err);
                  });
                }
              })
            }
          }
          .width('100%')
          .padding(0)
        }
        .layoutWeight(1)
        .align(Alignment.TopStart)
      }
    }
    .width('100%')
    .height('100%')
    .backgroundColor('#f8fafc')
    .padding({ top: 30, bottom: 30, left: 12, right: 12 })
  }
}
