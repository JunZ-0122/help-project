<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.csi.help.mapper.UserMapper">
    
    <resultMap id="UserResultMap" type="com.csi.help.entity.User">
        <id property="id" column="id"/>
        <result property="name" column="name"/>
        <result property="phone" column="phone"/>
        <result property="password" column="password"/>
        <result property="avatar" column="avatar"/>
        <result property="role" column="role"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
        <result property="age" column="age"/>
        <result property="gender" column="gender"/>
        <result property="address" column="address"/>
        <result property="emergencyContact" column="emergency_contact"/>
        <result property="emergencyPhone" column="emergency_phone"/>
        <result property="disabilities" column="disabilities"/>
        <result property="certifications" column="certifications"/>
        <result property="volunteerHours" column="volunteer_hours"/>
        <result property="rating" column="rating"/>
    </resultMap>
    
    <select id="findByPhone" resultMap="UserResultMap">
        SELECT * FROM users WHERE phone = #{phone}
    </select>
    
    <select id="findById" resultMap="UserResultMap">
        SELECT * FROM users WHERE id = #{id}
    </select>

    <select id="findByRole" resultMap="UserResultMap">
        SELECT * FROM users WHERE role = #{role}
    </select>
    
    <insert id="insert">
        INSERT INTO users (id, name, phone, password, role, status, created_at)
        VALUES (#{id}, #{name}, #{phone}, #{password}, #{role}, #{status}, NOW())
    </insert>
    
    <update id="update">
        UPDATE users
        <set>
            <if test="name != null">name = #{name},</if>
            <if test="avatar != null">avatar = #{avatar},</if>
            <if test="role != null">role = #{role},</if>
            <if test="age != null">age = #{age},</if>
            <if test="gender != null">gender = #{gender},</if>
            <if test="address != null">address = #{address},</if>
            <if test="emergencyContact != null">emergency_contact = #{emergencyContact},</if>
            <if test="emergencyPhone != null">emergency_phone = #{emergencyPhone},</if>
            <if test="disabilities != null">disabilities = #{disabilities},</if>
            <if test="certifications != null">certifications = #{certifications},</if>
            <if test="status != null">status = #{status},</if>
            updated_at = NOW()
        </set>
        WHERE id = #{id}
    </update>
    
    <update id="updateStatus">
        UPDATE users SET status = #{status}, updated_at = NOW()
        WHERE id = #{id}
    </update>
    
</mapper>
